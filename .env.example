# Copy to .env and adjust. Yaruk-OS reads these via pydantic-settings (prefix YARUK_).
# https://docs.pydantic.dev/latest/concepts/pydantic_settings/

# --- Logging ---
# YARUK_LOG_LEVEL=INFO

# --- GPU / memory routing ---
# YARUK_GPU_POLICY=auto
# YARUK_GPU_POLICY=cpu_only
# YARUK_GPU_POLICY=gpu_preferred
# YARUK_VRAM_THRESHOLD_MB=1024
# YARUK_RAM_THRESHOLD_MB=2048
# YARUK_CONFIDENCE_THRESHOLD=0.65

# --- Cache (disk) ---
# YARUK_CACHE_ENABLED=true
# YARUK_CACHE_DIR=/path/to/yaruk-cache
# YARUK_CACHE_MAX_ENTRIES=512
# YARUK_CACHE_TTL_SECONDS=

# --- Workers ---
# YARUK_USE_SUBPROCESS=true

# --- Segmenter ---
# YARUK_SEGMENTER_BACKEND=odl_pdf
# YARUK_OPENDATALOADER_PDF_SEGMENT_COMMAND=

# --- REST API (yaruk serve) ---
# YARUK_API_MAX_UPLOAD_BYTES=209715200
# YARUK_API_REQUIRE_PDF_MAGIC=true

# --- Hugging Face (VLM downloads) ---
# HF_TOKEN=
# YARUK_HF_REVISION=
